---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Button from "../components/Button.astro";
import Reviews from "../components/Reviews.astro";
import FAQ from "../components/FAQ.astro";
import ContactForm from "../components/ContactForm.astro";
import Footer from "../components/Footer.astro";
import ServiceIcon from "../components/ServiceIcon.astro";
import { Image } from "astro:assets";
import logoImg from "../assets/logo.avif";
import { services } from "../data/services.js";

// Dynamic import of service images
const images = import.meta.glob<{ default: ImageMetadata }>(
	"/src/assets/services/*.{jpeg,jpg,png,gif}",
);
---

<Layout title="Service de Nettoyage - Fin de Chantier - Événementiel">
	<main class="min-h-screen bg-brand-gray-light">
		<Navbar />

		{/* Hero Section */}
		<section class="container mx-auto px-6 py-20 md:py-32 grid md:grid-cols-2 gap-16 items-center relative overflow-hidden">
			<div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(184,144,71,0.05),transparent_45%)] pointer-events-none"></div>
			
			<div class="space-y-8 text-center md:text-left relative z-10">
				<h1 class="font-heading font-extrabold text-4xl md:text-6xl lg:text-7xl tracking-tight leading-[1.15] text-brand-navy">
					Quand la propreté <br />
					rencontre le <span class="text-brand-gold relative">soleil<span class="absolute -bottom-2 left-0 w-full h-1 bg-brand-gold/30 rounded"></span></span>
				</h1>

				<p class="text-slate-600 text-lg md:text-xl font-medium max-w-lg mx-auto md:mx-0 leading-relaxed">
					Spécialiste de la gestion <strong>Airbnb</strong>, du nettoyage <strong>Fin de Chantier</strong> & <strong>Événementiel</strong> sur l'Arc Méditerranéen (Narbonne, Béziers, Montpellier).
				</p>

				<div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start pt-2">
					<Button
						text="Demander un Devis"
						href="#devis"
						variant="primary"
					/>
					<Button
						text="Nos prestations"
						href="#services"
						variant="secondary"
					/>
				</div>
			</div>

			<div class="flex justify-center relative z-10">
				<div class="absolute -inset-4 bg-brand-gold/5 rounded-full blur-3xl -z-10"></div>
				<Image
					src={logoImg}
					alt="Logo Éclat du Sud"
					width={280}
					densities={[1.5, 2]}
					loading="eager"
					fetchpriority="high"
					class="w-64 md:w-80 rounded-2xl shadow-xl border border-brand-gray-border/60 hover:shadow-2xl hover:scale-[1.01] transition-all duration-500 h-auto bg-white p-4"
				/>
			</div>
		</section>

		{/* Services Section */}
		<section id="services" class="bg-white border-y border-brand-gray-border/80 py-24">
			<div class="container mx-auto px-6">
				<div class="text-center max-w-2xl mx-auto mb-20">
					<h2 class="font-heading font-bold text-3xl md:text-4xl text-brand-navy mb-4">
						Nos Missions Propreté
					</h2>
					<p class="text-brand-text-muted text-base font-medium">
						Des prestations de nettoyage sur-mesure adaptées aux exigences des professionnels et des particuliers.
					</p>
				</div>

				<div class="grid md:grid-cols-3 gap-8">
					{
						services.map((service) => (
							<a
								href={`/services/${service.slug}`}
								class="group block h-full"
							>
								<div class="bg-white border border-brand-gray-border rounded-2xl shadow-sm hover:shadow-lg hover:-translate-y-1.5 transition-all duration-300 h-full flex flex-col relative overflow-hidden">
									<div class="relative overflow-hidden">
										{images[`/src/assets/services/${service.imageFile}`] ? (
											<Image
												src={images[`/src/assets/services/${service.imageFile}`]()}
												alt={`${service.title} - Éclat du Sud Narbonne`}
												width={600}
												class="w-full h-52 object-cover border-b border-brand-gray-border group-hover:scale-105 transition-transform duration-700"
											/>
										) : (
											<div class="w-full h-52 bg-slate-100 border-b border-brand-gray-border flex items-center justify-center text-slate-400 font-bold">
												Image non disponible
											</div>
										)}
										
										{/* Floating Badge Icon */}
										<div class="absolute bottom-4 right-4 w-12 h-12 bg-white rounded-full border border-brand-gray-border flex items-center justify-center text-brand-navy shadow-md z-10 group-hover:scale-110 transition-transform duration-300">
											<ServiceIcon slug={service.slug} class="w-6 h-6 text-brand-navy" />
										</div>
									</div>

									<div class="p-8 flex flex-col flex-grow">
										<div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity font-bold text-lg z-10 bg-white/90 backdrop-blur-sm px-2.5 py-1 rounded-full border border-brand-gray-border text-brand-navy">
											↗
										</div>

										<h3 class="font-heading font-bold text-xl text-brand-navy mb-3 group-hover:text-brand-gold transition-colors">
											{service.title}
										</h3>
										<p class="text-brand-text-muted text-sm leading-relaxed mb-6 font-medium">
											{service.shortDesc}
										</p>
	
										<div class="mt-auto pt-4 text-xs font-bold uppercase tracking-wider text-brand-navy underline decoration-2 decoration-brand-gray-border group-hover:decoration-brand-gold transition-all">
											En savoir plus
										</div>
									</div>
								</div>
							</a>
						))
					}
				</div>
			</div>
		</section>

		<Reviews />
		<FAQ />

		<section class="container mx-auto px-6 py-24">
			<div class="max-w-4xl mx-auto">
				<ContactForm />
			</div>
		</section>

		<Footer />
	</main>
</Layout>
