---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Mentions Légales">
  <Navbar />
  
  <main class="bg-brand-gray-light min-h-screen py-20">
    <div class="bg-white border border-brand-gray-border/60 p-8 md:p-12 rounded-3xl shadow-sm max-w-4xl mx-auto">
      
      <h1 class="font-heading font-bold text-3xl md:text-4xl text-brand-navy mb-8 border-b border-brand-gray-border pb-4">Mentions Légales</h1>
      
      <div class="space-y-8 text-base text-brand-text font-medium leading-relaxed">
        <section>
          <h2 class="font-heading font-bold text-lg text-brand-navy mb-2">1. Éditeur du site</h2>
          <p class="text-slate-600">
            Le site <strong>Éclat du Sud</strong> est édité par @elyasejouk<br>
            Email : contact@eclatdusud.com
          </p>
        </section>

        <section>
          <h2 class="font-heading font-bold text-lg text-brand-navy mb-2">2. Hébergement</h2>
          <p class="text-slate-600">
            Ce site est hébergé par Hostinger.
          </p>
        </section>

        <section>
          <h2 class="font-heading font-bold text-lg text-brand-navy mb-2">3. Propriété Intellectuelle</h2>
          <p class="text-slate-600">
            L'ensemble de ce site relève de la législation française et internationale sur le droit d'auteur et la propriété intellectuelle. 
            Tous les droits de reproduction sont réservés.
          </p>
        </section>
        
        <div class="mt-12 pt-8 border-t border-brand-gray-border">
          <a href="/" class="font-bold text-brand-gold hover:text-brand-gold-light transition-colors">← Retour à l'accueil</a>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</Layout>