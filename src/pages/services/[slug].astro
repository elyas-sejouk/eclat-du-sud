---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import ContactForm from "../../components/ContactForm.astro";
import ServiceIcon from "../../components/ServiceIcon.astro";
import { services } from "../../data/services.js";

// 1. Astro asks: "Which pages should I build?"
export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

// 2. We retrieve the service info for the current page
const { service } = Astro.props;
---

<Layout title={service.title}>
  <Navbar />

  <main class="bg-brand-gray-light min-h-screen">
    {/* Page Header */}
    <section class="bg-brand-navy text-white py-24 text-center relative overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(184,144,71,0.06),transparent_40%)] pointer-events-none"></div>
      
      <div class="container mx-auto px-6 relative z-10">
        <div class="w-20 h-20 bg-brand-gold/15 text-brand-gold rounded-full flex items-center justify-center mx-auto mb-6">
          <ServiceIcon slug={service.slug} class="w-10 h-10" />
        </div>
        <h1 class="font-heading font-extrabold text-4xl md:text-5xl mb-6">{service.title}</h1>
        <p class="text-slate-300 text-lg md:text-xl font-medium max-w-3xl mx-auto leading-relaxed">
          {service.fullDesc}
        </p>
      </div>
    </section>

    {/* Details Section */}
    <section class="py-20">
      <div class="container mx-auto px-6 grid md:grid-cols-2 gap-16 items-start">
        
        {/* Features Inclusions Card */}
        <div class="bg-white border border-brand-gray-border/60 p-8 md:p-10 rounded-2xl shadow-sm">
          <h2 class="font-heading font-bold text-2xl text-brand-navy mb-6">
            Inclus dans la prestation :
          </h2>
          <ul class="space-y-4 text-brand-text">
            {
              service.features.map((item) => (
                <li class="flex items-start gap-3 font-semibold text-base leading-relaxed">
                  <svg class="w-5 h-5 text-brand-gold shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>

          <div class="mt-8 pt-8 border-t border-brand-gray-border/60 flex justify-between items-end">
            <div>
              <span class="block text-xs text-brand-text-muted font-bold uppercase tracking-wider mb-1">Tarif indicatif</span>
              <span class="font-heading font-bold text-xl text-brand-gold">{service.price}</span>
            </div>
          </div>
        </div>

        {/* Brand values / Guarantee */}
        <div class="space-y-8">
          <div class="space-y-4">
            <h3 class="font-heading font-bold text-2xl text-brand-navy">Pourquoi faire confiance à Éclat de Sud ?</h3>
            <p class="text-brand-text-muted text-base leading-relaxed font-medium">
              Nous utilisons exclusivement du matériel de qualité professionnelle et des produits éco-responsables de premier choix. Vous n'avez aucun équipement ni produit d'entretien à fournir.
            </p>
            <p class="text-brand-text font-bold text-base leading-relaxed">
              Garantie Propreté : Si le résultat ne correspond pas parfaitement à votre attente, nos équipes repassent gratuitement pour parfaire le nettoyage.
            </p>
          </div>

          <div class="bg-white border border-brand-gray-border/60 p-6 rounded-xl shadow-sm text-center">
            <p class="text-brand-text font-bold text-lg mb-2">Besoin d'un devis précis pour votre projet ?</p>
            <p class="text-brand-text-muted text-sm font-medium">Utilisez le formulaire ci-dessous pour nous faire part de vos critères.</p>
          </div>
        </div>
      </div>
    </section>

    {/* Quote Form Section */}
    <section class="container mx-auto px-6 pb-24">
      <div class="max-w-4xl mx-auto">
        <ContactForm />
      </div>
    </section>
  </main>

  <Footer />
</Layout>
