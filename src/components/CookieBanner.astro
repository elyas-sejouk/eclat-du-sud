---
// src/components/CookieBanner.astro
// Displays a consent banner and loads Google Analytics only after acceptance.
---

<div
  id="cookie-banner"
  class="hidden fixed bottom-4 inset-x-4 md:inset-x-auto md:right-6 md:max-w-sm bg-white border border-brand-gray-border/80 rounded-2xl shadow-xl p-6 z-50"
  role="dialog"
  aria-live="polite"
  aria-label="Consentement aux cookies"
>
  <h2 class="font-heading font-bold text-base text-brand-navy mb-2">
    Cookies & Vie privée <span class="text-brand-gold">🍪</span>
  </h2>
  <p class="text-sm text-brand-text-muted font-medium leading-relaxed mb-4">
    Nous utilisons des cookies de mesure d'audience (Google Analytics) pour améliorer votre expérience.
    <a href="/politique-de-confidentialite" class="text-brand-gold hover:underline font-bold">En savoir plus</a>
  </p>
  <div class="flex gap-3">
    <button
      id="cookie-accept"
      class="flex-1 bg-brand-navy hover:bg-brand-navy-light text-white font-bold text-sm py-2.5 px-4 rounded-full transition-all duration-300"
    >
      Accepter
    </button>
    <button
      id="cookie-refuse"
      class="flex-1 bg-transparent text-brand-navy hover:bg-brand-gray-light font-bold text-sm py-2.5 px-4 rounded-full border border-brand-gray-border transition-all duration-300"
    >
      Refuser
    </button>
  </div>
</div>

<script is:inline>
  (function () {
    var KEY = "eclat-cookie-consent";
    var GA_ID = "G-DVLQKWGKSB";
    var SIX_MONTHS_MS = 182 * 24 * 60 * 60 * 1000;

    var banner = document.getElementById("cookie-banner");

    function loadAnalytics() {
      if (window.gtagLoaded) return;
      window.gtagLoaded = true;
      var s = document.createElement("script");
      s.async = true;
      s.src = "https://www.googletagmanager.com/gtag/js?id=" + GA_ID;
      document.head.appendChild(s);
      window.dataLayer = window.dataLayer || [];
      window.gtag = function () {
        dataLayer.push(arguments);
      };
      window.gtag("js", new Date());
      window.gtag("config", GA_ID);
    }

    function getConsent() {
      try {
        var raw = localStorage.getItem(KEY);
        if (!raw) return null;
        var stored = JSON.parse(raw);
        if (Date.now() - stored.date > SIX_MONTHS_MS) {
          localStorage.removeItem(KEY);
          return null;
        }
        return stored.value;
      } catch (e) {
        return null;
      }
    }

    function setConsent(value) {
      try {
        localStorage.setItem(KEY, JSON.stringify({ value: value, date: Date.now() }));
      } catch (e) {}
      banner.classList.add("hidden");
      if (value === "accepted") loadAnalytics();
    }

    var consent = getConsent();
    if (consent === "accepted") {
      loadAnalytics();
    } else if (consent === null) {
      banner.classList.remove("hidden");
    }

    document.getElementById("cookie-accept").addEventListener("click", function () {
      setConsent("accepted");
    });
    document.getElementById("cookie-refuse").addEventListener("click", function () {
      setConsent("refused");
    });

    // Footer "Gérer les cookies" link re-opens the banner
    var manageLink = document.getElementById("manage-cookies");
    if (manageLink) {
      manageLink.addEventListener("click", function (e) {
        e.preventDefault();
        banner.classList.remove("hidden");
      });
    }
  })();
</script>
