---
import { services } from "../data/services.js";
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand-navy text-slate-300 py-16 border-t border-brand-navy-light">
  <div class="container mx-auto px-6">
    <div class="grid md:grid-cols-4 gap-12 text-center md:text-left items-start">
      <div class="flex flex-col items-center md:items-start space-y-4">
        <h2 class="font-heading font-bold text-2xl tracking-tight text-white">
          ÉCLAT DU SUD<span class="text-brand-gold">.</span>
        </h2>
        <p class="text-slate-400 text-sm max-w-sm leading-relaxed">
          Prestations de nettoyage d'excellence sur l'Arc Méditerranéen. Airbnb, fin de chantier, résidentiel et événementiel.
        </p>
        <div class="text-xs text-slate-500 flex flex-wrap gap-2 justify-center md:justify-start pt-2">
          <a
            href="/mentions-legales"
            class="hover:text-brand-gold transition-colors underline underline-offset-4"
            >Mentions Légales</a
          >
          <span>•</span>
          <span>© {currentYear} Éclat du Sud</span>
        </div>
      </div>

      <div class="flex flex-col gap-2.5 text-xs font-semibold tracking-wider text-slate-400 items-center md:items-start">
        <span class="text-brand-gold font-bold text-xs mb-2 tracking-widest uppercase">Prestations</span>
        {
          services.map((service) => (
            <a href={`/services/${service.slug}`} class="hover:text-brand-gold transition-colors font-medium text-slate-300 hover:underline underline-offset-4 decoration-1">
              {service.title}
            </a>
          ))
        }
      </div>

      <div class="flex flex-col gap-3 text-sm font-semibold tracking-wider uppercase text-slate-200 items-center md:items-start">
        <span class="text-brand-gold font-bold text-xs mb-1 tracking-widest text-slate-200">Navigation</span>
        <a href="/#services" class="hover:text-brand-gold transition-colors">Prestations</a>
        <a href="/contact" class="hover:text-brand-gold transition-colors">Demander un Devis</a>
        <a href="mailto:eclatdusud@gmail.com" class="hover:text-brand-gold transition-colors normal-case">eclatdusud@gmail.com</a>
      </div>

      <div class="flex flex-col items-center md:items-start gap-4">
        <span class="text-brand-gold font-bold text-xs tracking-widest uppercase">Suivez-nous</span>
        <a
          href="https://www.instagram.com/eclat.dusud/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-400 hover:text-brand-gold transition-colors duration-300 p-2 bg-brand-navy-light rounded-full"
          aria-label="Instagram"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="feather feather-instagram"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
