---
interface Props {
	text: string;
	href: string;
	variant?: "primary" | "secondary"; // 'primary' = Navy, 'secondary' = Gold outline
}

const { text, href, variant = "primary" } = Astro.props;

const baseStyle =
	"inline-block px-6 py-3 rounded-full font-bold text-base tracking-wide transition-all duration-300 text-center";

const colorStyle =
	variant === "primary"
		? "bg-brand-navy text-white hover:bg-brand-navy-light shadow-md hover:shadow-lg hover:-translate-y-0.5"
		: "bg-transparent text-brand-gold border-2 border-brand-gold hover:bg-brand-gold hover:text-white shadow-sm hover:-translate-y-0.5";
---

<a href={href} class={`${baseStyle} ${colorStyle}`}>
	{text}
</a>
