---
// src/components/ContactForm.astro
import { services } from "../data/services.js";
---

<div
  id="devis"
  class="bg-white border border-brand-gray-border/80 p-8 md:p-12 rounded-3xl shadow-xl relative overflow-hidden"
>
  <div class="absolute -top-16 -right-16 w-48 h-48 bg-brand-gold/10 rounded-full blur-3xl -z-0"></div>

  <div class="relative z-10">
    <div id="form-header" class="mb-10 text-center md:text-left">
      <h2 class="font-heading font-bold text-2xl md:text-3xl text-brand-navy mb-2">
        Demander un Devis Sur-Mesure
      </h2>
      <p class="text-brand-text-muted text-base font-medium">
        Remplissez ce formulaire pour recevoir une proposition tarifaire détaillée sous 24h.
      </p>
    </div>

    <div id="success-message" class="hidden text-center py-16">
      <div class="text-brand-gold mb-6 flex justify-center">
        <svg class="w-16 h-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0" />
        </svg>
      </div>
      <h3 class="font-heading font-bold text-3xl text-brand-navy mb-4">Votre demande a été reçue !</h3>
      <p class="text-brand-text-muted text-lg max-w-md mx-auto mb-8 font-medium">
        Notre équipe analyse vos besoins et vous transmet un devis personnalisé très rapidement.
      </p>
      <button
        id="reset-btn"
        class="bg-transparent text-brand-navy hover:bg-brand-navy hover:text-white font-bold px-8 py-3 rounded-full border-2 border-brand-navy transition-all duration-300 shadow-sm"
      >
        Nouvelle demande
      </button>
    </div>

    <form
      id="contact-form"
      action="https://formspree.io/f/mwvljvry"
      method="POST"
      class="space-y-6"
    >
      {/* --- IDENTITY SECTION --- */}
      <div class="grid md:grid-cols-2 gap-6">
        <div class="flex flex-col">
          <label class="font-bold mb-1.5 text-xs uppercase tracking-wider text-brand-navy/80">Nom complet</label>
          <input
            type="text"
            name="nom"
            required
            class="w-full p-3 rounded-lg border border-slate-200 focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 focus:outline-none transition-all text-brand-text"
            placeholder="Jean Dupont"
          />
        </div>
        <div class="flex flex-col">
          <label class="font-bold mb-1.5 text-xs uppercase tracking-wider text-brand-navy/80">Email</label>
          <input
            type="email"
            name="email"
            required
            class="w-full p-3 rounded-lg border border-slate-200 focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 focus:outline-none transition-all text-brand-text"
            placeholder="jean.dupont@email.com"
          />
        </div>
        <div class="flex flex-col">
          <label class="font-bold mb-1.5 text-xs uppercase tracking-wider text-brand-navy/80">Téléphone</label>
          <input
            type="tel"
            name="telephone"
            required
            class="w-full p-3 rounded-lg border border-slate-200 focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 focus:outline-none transition-all text-brand-text"
            placeholder="06 00 00 00 00"
          />
        </div>
        <div class="flex flex-col">
          <label class="font-bold mb-1.5 text-xs uppercase tracking-wider text-brand-navy/80">Ville d'intervention</label>
          <input
            type="text"
            name="ville"
            required
            class="w-full p-3 rounded-lg border border-slate-200 focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 focus:outline-none transition-all text-brand-text"
            placeholder="ex: Narbonne, Béziers..."
          />
        </div>

        <div class="flex flex-col md:col-span-2">
          <label class="font-bold mb-1.5 text-xs uppercase tracking-wider text-brand-navy/80">Type de prestation</label>
          <select
            id="service-selector"
            name="service"
            class="w-full p-3 rounded-lg border border-slate-200 bg-white focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 focus:outline-none transition-all text-brand-text cursor-pointer"
          >
            <option value="" disabled selected>-- Choisissez le service --</option>
            {
              services.map((service) => (
                <option value={service.title}>
                  {service.title}
                </option>
              ))
            }
            <option value="Autre">Autre / Spécifique</option>
          </select>
        </div>
      </div>

      <hr class="border-slate-100 my-6" />

      {/* --- GROUP: CLEANING (Hidden by default) --- */}
      <div
        id="group-cleaning"
        class="hidden space-y-6"
      >
        <div class="grid md:grid-cols-2 gap-6">
          <div class="flex flex-col">
            <label class="font-bold mb-1.5 text-xs uppercase tracking-wider text-brand-navy/80">Type de local</label>
            <select
              name="type_local"
              class="w-full p-3 rounded-lg border border-slate-200 bg-white focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 focus:outline-none transition-all text-brand-text"
            >
              <option>Appartement</option>
              <option>Maison</option>
              <option>Local Commercial / Bureau</option>
              <option>Immeuble entier</option>
              <option>Extérieur / Jardin</option>
            </select>
          </div>

          <div class="flex flex-col">
            <label class="font-bold mb-1.5 text-xs uppercase tracking-wider text-brand-navy/80">Surface (m²)</label>
            <input
              type="number"
              name="surface"
              placeholder="ex: 80"
              class="w-full p-3 rounded-lg border border-slate-200 focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 focus:outline-none transition-all text-brand-text"
            />
          </div>

          <div class="flex flex-col">
            <label class="font-bold mb-1.5 text-xs uppercase tracking-wider text-brand-navy/80">État actuel</label>
            <select
              name="etat_lieux"
              class="w-full p-3 rounded-lg border border-slate-200 bg-white focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 focus:outline-none transition-all text-brand-text font-medium"
            >
              <option value="Standard">Standard (Entretien)</option>
              <option value="Sale">Sale (Besoin d'un bon coup)</option>
              <option value="Tres_Sale">Très Sale / Insalubre</option>
              <option value="Chantier">Fin de Chantier (Poussière)</option>
              <option value="Sinistre">Après Sinistre / Inondation</option>
            </select>
          </div>

          <div class="flex flex-col">
            <label class="font-bold mb-1.5 text-xs uppercase tracking-wider text-brand-navy/80">Fréquence d'intervention</label>
            <select
              name="frequence"
              class="w-full p-3 rounded-lg border border-slate-200 bg-white focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 focus:outline-none transition-all text-brand-text"
            >
              <option value="Ponctuel">Une seule fois (One Shot)</option>
              <option value="Hebdo">Régulier (Hebdomadaire)</option>
              <option value="Mensuel">Régulier (Mensuel)</option>
              <option value="Saisonnier">Saisonnier (Début/Fin saison)</option>
            </select>
          </div>
        </div>

        <div class="bg-brand-gray-light/40 p-6 rounded-xl border border-brand-gray-border/60">
          <label class="font-bold mb-4 block text-xs uppercase tracking-wider text-brand-navy/80">Options souhaitées</label>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm font-medium text-brand-text">
            <label class="flex items-center gap-3 cursor-pointer select-none">
              <input
                type="checkbox"
                name="opt_eco"
                class="w-5 h-5 rounded border-slate-200 text-brand-gold focus:ring-brand-gold/20 accent-brand-gold"
              />
              Produits Écologiques
            </label>
            <label class="flex items-center gap-3 cursor-pointer select-none">
              <input
                type="checkbox"
                name="opt_linge"
                class="w-5 h-5 rounded border-slate-200 text-brand-gold focus:ring-brand-gold/20 accent-brand-gold"
              />
              Gestion Linge
            </label>
            <label class="flex items-center gap-3 cursor-pointer select-none">
              <input
                type="checkbox"
                name="opt_materiel"
                class="w-5 h-5 rounded border-slate-200 text-brand-gold focus:ring-brand-gold/20 accent-brand-gold"
              />
              Location Matériel
            </label>
            <label class="flex items-center gap-3 cursor-pointer select-none">
              <input
                type="checkbox"
                name="opt_urgence"
                class="w-5 h-5 rounded border-slate-200 text-red-500 focus:ring-red-500/20 accent-red-500"
              />
              <span class="text-red-600 font-bold">URGENCE / 24H</span>
            </label>
          </div>
        </div>
      </div>

      {/* --- GROUP: MOVING / DEBARRAS (Hidden by default) --- */}
      <div
        id="group-moving-debarras"
        class="hidden space-y-6"
      >
        <div class="grid md:grid-cols-2 gap-6">
          <div class="flex flex-col">
            <label class="font-bold mb-1.5 text-xs uppercase tracking-wider text-brand-navy/80">Étage / Accès ?</label>
            <input
              type="text"
              name="etage_acces"
              placeholder="ex: 2ème sans ascenseur"
              class="w-full p-3 rounded-lg border border-slate-200 focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 focus:outline-none transition-all text-brand-text"
            />
          </div>

          <div class="flex flex-col">
            <label class="font-bold mb-1.5 text-xs uppercase tracking-wider text-brand-navy/80">Besoin d'un camion ?</label>
            <select
              name="besoin_camion"
              class="w-full p-3 rounded-lg border border-slate-200 bg-white focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 focus:outline-none transition-all text-brand-text"
            >
              <option value="Non">Non, juste de l'aide à la manutention</option>
              <option value="Oui_20m3">Oui, camion 20m3</option>
              <option value="Oui_Petit">Oui, petite camionnette</option>
              <option value="Ne_sais_pas">Je ne sais pas</option>
            </select>
          </div>

          <div class="flex flex-col md:col-span-2">
            <label class="font-bold mb-1.5 text-xs uppercase tracking-wider text-brand-navy/80">Volume estimé / Type d'objets</label>
            <textarea
              name="volume_objets"
              rows="2"
              placeholder="ex: Un canapé, 10 cartons et un frigo..."
              class="w-full p-3 rounded-lg border border-slate-200 focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 focus:outline-none transition-all text-brand-text"
            ></textarea>
          </div>
        </div>
      </div>

      {/* --- COMMON BOTTOM --- */}
      <div class="grid md:grid-cols-2 gap-6">
        <div class="flex flex-col">
          <label class="font-bold mb-1.5 text-xs uppercase tracking-wider text-brand-navy/80">Date souhaitée</label>
          <input
            type="date"
            name="date"
            class="w-full p-3 rounded-lg border border-slate-200 focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 focus:outline-none transition-all text-brand-text"
          />
        </div>
        <div class="flex flex-col md:col-span-2">
          <label class="font-bold mb-1.5 text-xs uppercase tracking-wider text-brand-navy/80">Précisions supplémentaires</label>
          <textarea
            name="message"
            rows="3"
            class="w-full p-3 rounded-lg border border-slate-200 focus:border-brand-gold focus:ring-2 focus:ring-brand-gold/20 focus:outline-none transition-all text-brand-text"
            placeholder="Codes d'accès, clés, contraintes horaires..."
          ></textarea>
        </div>
      </div>

      <button
        type="submit"
        class="w-full bg-brand-navy hover:bg-brand-navy-light text-white font-bold text-lg py-4 rounded-full shadow-md hover:shadow-lg transition-all duration-300 mt-4"
      >
        Obtenir mon Devis
      </button>
    </form>

    <p
      id="error-message"
      class="hidden text-red-600 font-bold mt-4 text-center"
    >
      Oups ! Une erreur est survenue lors de l'envoi. Veuillez réessayer.
    </p>
  </div>
</div>

<script>
  const form = document.getElementById("contact-form");
  const successMessage = document.getElementById("success-message");
  const errorMessage = document.getElementById("error-message");
  const formHeader = document.getElementById("form-header");
  const resetBtn = document.getElementById("reset-btn");

  // Elements for Dynamic Logic
  const serviceSelector = document.getElementById("service-selector");
  const groupCleaning = document.getElementById("group-cleaning");
  const groupMoving = document.getElementById("group-moving-debarras");

  // Helper to toggle visibility and required attributes
  function toggleGroup(group, show) {
    if (!group) return;

    if (show) {
      group.classList.remove("hidden");
      const inputs = group.querySelectorAll("input, select, textarea");
      inputs.forEach((input) => {
        if (input.type !== "checkbox" && input.type !== "hidden") {
          input.setAttribute("required", "true");
        }
      });
    } else {
      group.classList.add("hidden");
      const inputs = group.querySelectorAll("input, select, textarea");
      inputs.forEach((input) => {
        input.removeAttribute("required");
      });
    }
  }

  function handleServiceChange() {
    const selectedService = (serviceSelector as HTMLSelectElement).value;

    const movingKeywords = ["Débarras", "Déménagement"];
    const isMoving = movingKeywords.some((keyword) =>
      selectedService.includes(keyword),
    );

    if (isMoving) {
      toggleGroup(groupCleaning, false);
      toggleGroup(groupMoving, true);
    } else {
      if (selectedService && selectedService !== "") {
        toggleGroup(groupCleaning, true);
        toggleGroup(groupMoving, false);
      } else {
        toggleGroup(groupCleaning, false);
        toggleGroup(groupMoving, false);
      }
    }
  }

  // Initial State: Hide all
  toggleGroup(groupCleaning, false);
  toggleGroup(groupMoving, false);

  // Listener
  serviceSelector?.addEventListener("change", handleServiceChange);

  form?.addEventListener("submit", async function (e) {
    e.preventDefault();
    const formData = new FormData(form as HTMLFormElement);
    try {
      const response = await fetch(form.getAttribute("action") as string, {
        method: "POST",
        body: formData,
        headers: { Accept: "application/json" },
      });
      if (response.ok) {
        form.classList.add("hidden");
        formHeader?.classList.add("hidden");
        errorMessage?.classList.add("hidden");
        successMessage?.classList.remove("hidden");
        (form as HTMLFormElement).reset();

        toggleGroup(groupCleaning, false);
        toggleGroup(groupMoving, false);
      } else {
        throw new Error("Erreur");
      }
    } catch (error) {
      errorMessage?.classList.remove("hidden");
    }
  });

  resetBtn?.addEventListener("click", () => {
    successMessage?.classList.add("hidden");
    form?.classList.remove("hidden");
    formHeader?.classList.remove("hidden");
  });
</script>
