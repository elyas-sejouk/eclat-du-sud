---
import "../styles/global.css";
// Import heading font (Outfit) - weights 500, 600, 700
import "@fontsource/outfit/500.css";
import "@fontsource/outfit/600.css";
import "@fontsource/outfit/700.css";

// Import body font (Inter) - weights 400, 500, 600
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";

interface Props {
	title?: string;
}

const { title } = Astro.props;
const defaultSiteTitle = "Éclat du Sud";
const displayTitle = title ? `${title} | ${defaultSiteTitle}` : defaultSiteTitle;
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="description"
			content="Nettoyage professionnel Airbnb, Fin de Chantier & Événementiel à Narbonne et environs. Devis gratuit sous 24h."
		/>
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/ico.png" />
		<meta name="generator" content={Astro.generator} />

		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-DVLQKWGKSB"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-DVLQKWGKSB');
		</script>

		<title>{displayTitle}</title>
	</head>

	<body class="bg-brand-gray-light text-brand-text font-sans antialiased">
		<slot />
	</body>
</html>
